{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyAlias",
  "version": "0.1.0",
  "identifier": "dev.hannesgnann.easyalias",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EasyAlias",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 Hannes Gnann",
    "licenseFile": "../LICENSE",
    "shortDescription": "Manage terminal aliases through a desktop UI",
    "longDescription": "EasyAlias creates and manages local bash or zsh aliases without requiring manual shell configuration edits."
  }
}
